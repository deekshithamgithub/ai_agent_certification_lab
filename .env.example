# Copy this file to ".env" for local development (and never commit the
# real ".env" file to Git — it's already excluded in .gitignore).
#
# On a hosting platform (Render, Railway, PythonAnywhere, etc.), you set
# these same values in the platform's "Environment Variables" dashboard
# instead of using this file.

# ---------------------------------------------------------------------------
# SECRET_KEY (required for any real/public deployment)
# ---------------------------------------------------------------------------
# Used by Flask to sign session cookies (keeps users logged in securely).
# If this is left unset, the app falls back to a hardcoded development
# default — fine for testing on your own machine, NOT safe once the app
# is live on the internet, since anyone could forge a login session.
#
# Generate a strong random value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
SECRET_KEY=paste-a-long-random-string-here

# ---------------------------------------------------------------------------
# PORT (optional — most hosting platforms set this automatically)
# ---------------------------------------------------------------------------
# The port the app listens on. Render/Railway/etc. inject this themselves,
# so you usually don't need to set it yourself except for local testing.
PORT=5000

# ---------------------------------------------------------------------------
# FLASK_DEBUG (optional)
# ---------------------------------------------------------------------------
# Set to "false" in production so Flask doesn't expose the interactive
# debugger/stack traces to visitors. Defaults to "true" if unset, which is
# only appropriate for local development.
FLASK_DEBUG=false

# ---------------------------------------------------------------------------
# DATABASE_URL (optional — only needed if you switch from SQLite to Postgres)
# ---------------------------------------------------------------------------
# Uncomment and set this if you upgrade to a hosted Postgres database
# (recommended for real production use, since SQLite's file gets wiped on
# most free hosting platforms whenever the app restarts/redeploys).
# Example format: postgresql://username:password@host:5432/dbname
# DATABASE_URL=postgresql://user:password@host:5432/dbname
